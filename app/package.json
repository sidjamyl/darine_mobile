{
  "name": "app",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.5.5",
      "@types/express": "^5.0.1",
      "@trpc/client": "^11.16.0",
      "@better-auth/expo": "1.5.5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @app/db db:push",
    "db:studio": "turbo -F @app/db db:studio",
    "db:generate": "turbo -F @app/db db:generate",
    "db:migrate": "turbo -F @app/db db:migrate",
    "db:start": "turbo -F @app/db db:start",
    "db:watch": "turbo -F @app/db db:watch",
    "db:stop": "turbo -F @app/db db:stop",
    "db:down": "turbo -F @app/db db:down"
  },
  "dependencies": {
    "@app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.11"
}
